PORT=8081
NODE_ENV=production

# Full production API base URL, used in emails.
BASE_URL=https://api.example.com

# Frontend origins allowed by CORS and Socket.IO. Use comma-separated values for multiple domains.
FRONTEND_URL=https://app.example.com
FRONTEND_URLS=https://app.example.com,https://www.example.com

# Preferred production Mongo setting. Use this OR MONGODB_URL + DB_NAME.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/videoAPP
MONGODB_URL=
DB_NAME=

ACCESS_TOKEN_SECRET=replace-with-long-random-secret
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_SECRET=replace-with-long-random-secret
REFRESH_TOKEN_EXPIRY=7d

CLOUDINARY_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

GOOGLE_HOST=smtp.gmail.com
GOOGLE_PORT=587
GOOGLE_MAIL=your-email@example.com
GOOGLE_PASSWORD=your-app-password

# Optional mail providers if used by your deployment.
SENDGRID_API_KEY=
SENDGRID_SERVER=
SENDGRID_USERNAME=
SENDGRID_PORT=
ZOHO_PORT=
ZOHO_HOST=
ZOHO_MAIL=
ZOHO_PASSWORD=
RESEND_API_KEY=
RESEND_FROM=
MAIL_FROM=
BREVO_SMTP_API=
